export default defineConfig({
  plugins: [react()],

  resolve: {
    alias: {
      '@': path.resolve(__dirname, './src'),
    },
  },

  build: {
    // Target modern browsers untuk output lebih kecil
    target: 'es2020',

    chunkSizeWarningLimit: 600,

    rollupOptions: {
      output: {
        // Manual chunking: pisahkan vendor besar agar browser bisa cache terpisah
        manualChunks: {
          // React core
          'vendor-react': ['react', 'react-dom', 'react-router-dom'],

          // Supabase (pisah karena jarang berubah)
          'vendor-supabase': ['@supabase/supabase-js', '@supabase/ssr'],

          // Editor
          'vendor-editor': ['react-quill-new'],
        },

        // Naming pattern untuk cache busting
        chunkFileNames: 'assets/js/[name]-[hash].js',
        entryFileNames: 'assets/js/[name]-[hash].js',
        assetFileNames: 'assets/[ext]/[name]-[hash].[ext]',
      },
    },

    // Minifikasi optimal
